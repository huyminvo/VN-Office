{
  "name": "ai-agent-plugin",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "node scripts/dev.js",
    "build": "biome check --error-on-warnings ./src && tsc --noEmit && vite build && node scripts/build.js",
    "build:local": "biome check --error-on-warnings ./src && tsc --noEmit && vite build && node scripts/build.js && node scripts/move.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@assistant-ui/react": "^0.11.0",
    "@assistant-ui/react-ai-sdk": "^1.1.0",
    "@assistant-ui/react-markdown": "^0.11.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.2",
    "@google/genai": "^1.30.0",
    "@lmstudio/sdk": "^1.5.0",
    "@mistralai/mistralai": "^1.11.0",
    "@openrouter/ai-sdk-provider": "^1.2.3",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^24.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.23.12",
    "i18next": "^25.5.2",
    "lodash.clonedeep": "^4.5.0",
    "ollama": "^0.5.17",
    "openai": "^5.22.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.7.3",
    "react-shiki": "^0.8.0",
    "react-svg": "^16.3.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "together-ai": "^0.22.0",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@playwright/test": "^1.57.0",
    "@types/codemirror": "^5.60.16",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.14",
    "path": "^0.12.7",
    "tw-animate-css": "^1.3.6",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.14"
  }
}
